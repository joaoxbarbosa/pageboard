{
    "name": "PageBoard",
    "description": "Turn any page into a whiteboard",
    "version": "1.0",
    "manifest_version": 3,
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "css": ["content.css"]
      }
    ],
    "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
    },
    "permissions": [
      "storage"
    ]
}